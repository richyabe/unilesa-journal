# UJSMS — Environment Variables
# Copy this file to .env.local and fill in your Supabase project values.
# NEVER commit .env.local to version control.

# Supabase Project URL (found in: Project Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Anon/Public Key (found in: Project Settings → API → Project API Keys → anon/public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────
# HOW TO USE ON VERCEL:
# 1. Go to your Vercel project → Settings → Environment Variables
# 2. Add SUPABASE_URL and SUPABASE_ANON_KEY with your values
# 3. For static HTML, these are injected via a build step (see README)
# ─────────────────────────────────────────────────────────────────
